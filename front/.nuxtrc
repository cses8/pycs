imports.autoImport=true

nitro.storage.db.driver=fs
nitro.storage.db.base=./.data/db

ssr=false

build.analyze=true

vite.build.minify=terser
vite.build.minify.terserOptions.toplevel=true
vite.build.minify.terserOptions.compress.drop_console=false
vite.build.minify.terserOptions.mangle.toplevel=true

devtools.timeline.enable=true

compatibilityDate=2024-10-15

typescript.typeCheck=true
typescript.strict=true
typescript.builder=vite

future.compatibilityVersion=4
