{
  "name": "pysc",
  "private": true,
  "type": "module",
  "description": "Philippine Yuh Chiau School. Experience the Culture of Excellence. Transforming Lives through Education with Quality Assurance",
  "scripts": {
    "build": "nuxt build --dotenv .env.prod",
    "dev": "nuxt dev --dotenv .env.local",
    "generate": "nuxt generate --dotenv .env.prod",
    "compress": "bunx gzipper compress ./.output/public --include js,css,html,xml,json,svg,txt --gzip --remove-larger --workers 8 --verbose",
    "generate:compressed": "bun run generate && bun run compress",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@nuxt/icon": "2.2.1",
    "@pinia/nuxt": "0.11.3",
    "@popperjs/core": "^2.11.8",
    "@primevue/forms": "^4.5.5",
    "@primevue/themes": "^4.5.4",
    "@vueuse/core": "^14.2.1",
    "@vueuse/motion": "^3.0.3",
    "dayjs-nuxt": "^2.1.11",
    "lodash.clonedeep": "^4.5.0",
    "motion-v": "^2.2.1",
    "nuxt": "^4.4.2",
    "nuxt-auth-sanctum": "2.3.3",
    "nuxt-delay-hydration": "1.3.8",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "quill": "^2.0.3",
    "tailwindcss-primeui": "^0.6.1",
    "v-calendar": "^3.1.2",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "vue-use-spring": "^0.3.3"
  },
  "devDependencies": {
    "@inspira-ui/plugins": "^0.0.2",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint": "1.15.2",
    "@nuxtjs/critters": "^0.9.0",
    "@nuxtjs/fontaine": "^0.5.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@primevue/nuxt-module": "^4.5.5",
    "@types/lodash.clonedeep": "^4.5.9",
    "@vueuse/nuxt": "14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^10.2.1",
    "gzipper": "^8.2.1",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "vue-tsc": "^3.2.7"
