{
  "name": "pysc",
  "private": true,
  "type": "module",
  "description": "Philippine Yuh Chiau School. Experience the Culture of Excellence. Transforming Lives through Education with Quality Assurance",
  "scripts": {
    "build": "nuxt build --dotenv .env.prod",
    "dev": "nuxt dev --dotenv .env.local --host localhost --port 4000",
    "lint": "eslint app tests playwright.config.ts vitest.config.ts",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test",
    "audit:security": "bun audit --audit-level high",
    "quality:check": "bun run lint && vue-tsc --noEmit && bun run test:unit",
    "generate": "nuxt generate --dotenv .env.prod",
    "compress": "bunx gzipper compress ./.output/public --include js,css,html,xml,json,svg,txt --gzip --remove-larger --workers 8 --verbose",
    "generate:compressed": "bun run generate && bun run compress",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@nuxt/icon": "2.2.1",
    "@pinia/nuxt": "0.11.3",
    "@popperjs/core": "^2.11.8",
    "@primevue/forms": "^4.5.5",
    "@primevue/themes": "^4.5.4",
    "@vueuse/core": "^14.2.1",
    "@vueuse/motion": "^3.0.3",
    "dayjs-nuxt": "^2.1.11",
    "lodash.clonedeep": "^4.5.0",
    "motion-v": "^2.2.1",
    "nuxt": "^4.4.2",
    "nuxt-auth-sanctum": "2.3.3",
    "nuxt-delay-hydration": "1.3.8",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "quill": "^2.0.3",
    "sanitize-html": "^2.17.3",
    "tailwindcss-primeui": "^0.6.1",
    "v-calendar": "^3.1.2",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "vue-use-spring": "^0.3.3"
  },
  "devDependencies": {
    "@iconify-json/solar": "^1.2.5",
    "@inspira-ui/plugins": "^0.0.2",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/test-utils": "^4.0.2",
    "@nuxtjs/critters": "^0.9.0",
    "@nuxtjs/fontaine": "^0.5.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@playwright/test": "^1.59.1",
    "@primevue/nuxt-module": "^4.5.5",
    "@types/lodash.clonedeep": "^4.5.9",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.8",
    "@vueuse/nuxt": "14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^10.2.1",
    "gzipper": "^8.2.1",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  },
  "overrides": {
    "brace-expansion": "5.0.5",
    "defu": "6.1.7",
    "flatted": "3.4.2",
    "glob": "10.5.0",
    "h3": "1.15.11",
    "js-yaml": "4.1.1",
    "koa": "3.2.0",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "minimatch": "10.2.5",
    "node-forge": "1.4.0",
    "picomatch": "4.0.4",
    "postcss": "8.5.10",
    "tar": "7.5.13",
    "yaml": "2.8.3"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "esbuild",
    "sharp",
    "vue-demi",
    "unrs-resolver"
  ]
}
